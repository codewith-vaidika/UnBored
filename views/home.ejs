      <i data-lucide="sparkles" class="w-4 h-4 text-white"></i>
      <span class="text-xs font-semibold uppercase tracking-widest text-white/90">
        AI-Powered Recommendations
      </span>
    </div>

    <!-- Massive Typography -->
    <h1 class="font-jakarta text-6xl md:text-7xl lg:text-8xl font-extrabold text-white tracking-tight leading-[1.1] mb-8 max-w-5xl animate-fade-in drop-shadow-lg" style="animation-delay: 0.2s;">
