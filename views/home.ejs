<!-- ── HERO SLIDER SCRIPT ──────────────────────────────── -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const images = [
      'https://images.unsplash.com/photo-1498654896293-37aacf113fd9?q=80&w=1600&auto=format&fit=crop', // Cozy cafe / food
      'https://images.unsplash.com/photo-1469474968028-56623f02e42e?q=80&w=1600&auto=format&fit=crop', // Hiking / outdoor
      'https://images.unsplash.com/photo-1511512578047-dfb367046420?q=80&w=1600&auto=format&fit=crop'  // Gaming / indoor
    ];
    
    const slider = document.getElementById('hero-slider');
    
    // Create image elements
    images.forEach((src, idx) => {
      const img = document.createElement('div');
      img.className = 'absolute inset-0 bg-cover bg-center transition-opacity duration-1000 ease-in-out';
      img.style.backgroundImage = `url('${src}')`;
      img.style.opacity = idx === 0 ? '1' : '0';
      slider.appendChild(img);
    });

    const slides = slider.children;
    let current = 0;

    // Crossfade every 5 seconds
    setInterval(() => {
      slides[current].style.opacity = '0';
      current = (current + 1) % slides.length;
      slides[current].style.opacity = '1';
    }, 5000);
  });
</script>