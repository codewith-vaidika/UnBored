      <a href="<%= currentUser ? '/dashboard' : '/signup' %>" class="flex items-center justify-center gap-3 w-full px-8 py-5 rounded-full bg-white text-slate-900 font-jakarta font-bold text-lg transition-all duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1 hover:bg-slate-50">
