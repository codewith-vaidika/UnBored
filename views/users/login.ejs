<% layout('/layouts/boilerplate') %>

<!-- ═══════════════════════════════════════════════════════════
  LOGIN PAGE
  Split-screen layout: left = form, right = decorative panel
════════════════════════════════════════════════════════════ -->
<div class="min-h-[calc(100vh-4rem)] flex">

  <!-- ── Left: Form Panel ───────────────────────────────── -->
  <div class="flex-1 flex items-center justify-center px-6 py-16 bg-white dark:bg-slate-900">
    <div class="w-full max-w-md">

      <!-- Logo mark -->
      <a href="/" class="inline-flex items-center gap-2 text-accent font-extrabold text-xl mb-8">
        <span class="text-2xl">✨</span> UnBored
      </a>

      <!-- Heading -->
      <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white mb-1">
        Welcome back
      </h1>
      <p class="text-slate-500 dark:text-slate-400 mb-8 text-sm">
        New here?
        <a href="/signup" class="text-accent font-semibold hover:underline">Create a free account →</a>
      </p>

      <!-- Login Form -->
      <form id="login-form" method="POST" action="/login" novalidate class="space-y-5">

        <!-- Username -->
        <div>
          <label for="username" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
            Username
          </label>
          <div class="relative">
            <span class="absolute inset-y-0 left-3.5 flex items-center text-slate-400 text-lg pointer-events-none">👤</span>
            <input
              id="username"
              name="username"
              type="text"
              autocomplete="username"
              required
              placeholder="your_username"
              value="<%= typeof formData !== 'undefined' ? formData.username || '' : '' %>"
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700
                     bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white
                     placeholder:text-slate-400 text-sm
                     focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent
                     transition-all duration-200"
            />
          </div>
        </div>

        <!-- Password -->
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <label for="password" class="block text-sm font-medium text-slate-700 dark:text-slate-300">
              Password
            </label>
            <a href="#" class="text-xs text-accent hover:underline">Forgot password?</a>
          </div>
          <div class="relative">
            <span class="absolute inset-y-0 left-3.5 flex items-center text-slate-400 text-lg pointer-events-none">🔒</span>
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
              placeholder="••••••••"
              class="w-full pl-10 pr-12 py-3 rounded-xl border border-slate-200 dark:border-slate-700
                     bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white
                     placeholder:text-slate-400 text-sm
                     focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent
                     transition-all duration-200"
            />
            <!-- Show/hide toggle -->
            <button
              type="button"
              id="toggle-password"
              aria-label="Toggle password visibility"
              class="absolute inset-y-0 right-3.5 flex items-center text-slate-400 hover:text-slate-600 text-sm"
            >👁️</button>
          </div>
        </div>

        <!-- Submit -->
        <button
          id="login-submit"
          type="submit"
          class="w-full flex items-center justify-center gap-2 py-3 px-4 rounded-xl
                 bg-accent hover:bg-accent-hover text-white font-semibold text-sm
                 shadow-sm hover:shadow-md hover:-translate-y-0.5
                 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
        >
          Sign In
          <span class="text-base">→</span>
        </button>

        <!-- Divider -->
        <div class="relative flex items-center gap-3 py-1">
          <div class="flex-1 border-t border-slate-200 dark:border-slate-700"></div>
          <span class="text-xs text-slate-400">or continue with</span>
          <div class="flex-1 border-t border-slate-200 dark:border-slate-700"></div>
        </div>

        <!-- Social placeholder (disabled for now) -->
        <button
          type="button"
          disabled
          class="w-full flex items-center justify-center gap-2.5 py-3 px-4 rounded-xl
                 border border-slate-200 dark:border-slate-700
                 text-slate-500 dark:text-slate-400 text-sm font-medium
                 cursor-not-allowed opacity-60"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google <span class="text-xs text-slate-400">(coming soon)</span>
        </button>

      </form>

    </div>
  </div>

  <!-- ── Right: Decorative Panel (hidden on mobile) ─────── -->
  <div class="hidden lg:flex flex-1 flex-col items-center justify-center
              bg-gradient-to-br from-indigo-600 via-violet-600 to-purple-700
              relative overflow-hidden px-10 text-white">

    <!-- Background blobs -->
    <div class="absolute top-[-20%] right-[-15%] w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-[-10%] left-[-10%] w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 text-center max-w-sm">
      <div class="text-6xl mb-6">🎯</div>
      <h2 class="text-3xl font-extrabold mb-4 leading-tight">
        Stop scrolling.<br />Start living.
      </h2>
      <p class="text-indigo-200 text-sm leading-relaxed">
        Your personal AI activity guide. Tell us your mood, time, and budget —
        we'll find the perfect thing to do.
      </p>

      <!-- Feature pills -->
      <div class="mt-8 flex flex-wrap justify-center gap-2">
        <span class="px-3 py-1.5 bg-white/15 backdrop-blur-sm rounded-full text-xs font-medium">✨ AI-Powered</span>
        <span class="px-3 py-1.5 bg-white/15 backdrop-blur-sm rounded-full text-xs font-medium">🎭 Mood-based</span>
        <span class="px-3 py-1.5 bg-white/15 backdrop-blur-sm rounded-full text-xs font-medium">💰 Budget-aware</span>
        <span class="px-3 py-1.5 bg-white/15 backdrop-blur-sm rounded-full text-xs font-medium">📍 Location-smart</span>
      </div>
    </div>
  </div>

</div>

<!-- Password toggle + form loading state -->
<script>
  // Toggle password visibility
  document.getElementById('toggle-password').addEventListener('click', function () {
    const input = document.getElementById('password');
    const isText = input.type === 'text';
    input.type = isText ? 'password' : 'text';
    this.textContent = isText ? '👁️' : '🙈';
  });

  // Add loading spinner on submit
  document.getElementById('login-form').addEventListener('submit', function () {
    const btn = document.getElementById('login-submit');
    btn.innerHTML = '<svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg> Signing in…';
    btn.disabled = true;
  });
</script>