<% layout('/layouts/boilerplate') %>

<!-- ═══════════════════════════════════════════════════════════
  SIGNUP PAGE
  Split-screen: left = decorative panel, right = form
════════════════════════════════════════════════════════════ -->
<div class="min-h-[calc(100vh-4rem)] flex">

  <!-- ── Left: Decorative Panel (hidden on mobile) ─────── -->
  <div class="hidden lg:flex flex-1 flex-col items-center justify-center
              bg-gradient-to-br from-emerald-500 via-teal-500 to-cyan-600
              relative overflow-hidden px-10 text-white">

    <!-- Background blobs -->
    <div class="absolute top-[-20%] left-[-15%] w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 text-center max-w-sm">
      <div class="text-6xl mb-6">🌟</div>
      <h2 class="text-3xl font-extrabold mb-4 leading-tight">
        Join 10,000+<br />people who got<br />un-bored.
      </h2>
      <p class="text-emerald-100 text-sm leading-relaxed">
        Create your free account and get instant AI-powered activity
        recommendations tailored to your mood and interests.
      </p>

      <!-- Testimonial -->
      <div class="mt-8 bg-white/15 backdrop-blur-sm rounded-2xl p-5 text-left">
        <p class="text-sm text-white leading-relaxed">
          "UnBored helped me discover a pottery class near my home. Best Saturday ever! 🏺"
        </p>
        <div class="mt-3 flex items-center gap-2">
          <div class="w-7 h-7 rounded-full bg-white/30 flex items-center justify-center text-xs font-bold">P</div>
          <span class="text-xs text-emerald-100">Priya S. · Mumbai</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Right: Form Panel ──────────────────────────────── -->
  <div class="flex-1 flex items-center justify-center px-6 py-16 bg-white dark:bg-slate-900">
    <div class="w-full max-w-md">

      <!-- Logo mark -->
      <a href="/" class="inline-flex items-center gap-2 text-accent font-extrabold text-xl mb-8">
        <span class="text-2xl">✨</span> UnBored
      </a>

      <!-- Heading -->
      <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white mb-1">
        Create your account
      </h1>
      <p class="text-slate-500 dark:text-slate-400 mb-8 text-sm">
        Already have one?
        <a href="/login" class="text-accent font-semibold hover:underline">Sign in →</a>
      </p>

      <!-- Registration Form -->
      <form id="signup-form" method="POST" action="/signup" enctype="multipart/form-data" novalidate class="space-y-5">

        <!-- Username -->
        <div>
          <label for="username" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
            Username
          </label>
          <div class="relative">
            <span class="absolute inset-y-0 left-3.5 flex items-center text-slate-400 text-lg pointer-events-none">👤</span>
            <input
              id="username"
              name="username"
              type="text"
              autocomplete="username"
              required
              minlength="3"
              maxlength="30"
              pattern="[a-zA-Z0-9_]+"
              placeholder="cooluser_123"
              value="<%= typeof formData !== 'undefined' ? formData.username || '' : '' %>"
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700
                     bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white
                     placeholder:text-slate-400 text-sm
                     focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent
                     transition-all duration-200"
            />
          </div>
          <p class="text-xs text-slate-400 mt-1.5">3–30 characters · letters, numbers, underscores only</p>
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
            Email address
          </label>
          <div class="relative">
            <span class="absolute inset-y-0 left-3.5 flex items-center text-slate-400 text-lg pointer-events-none">📧</span>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              placeholder="you@example.com"
              value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>"
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700
                     bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white
                     placeholder:text-slate-400 text-sm
                     focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent
                     transition-all duration-200"
            />
          </div>
        </div>

        <!-- Password -->
        <div>
          <label for="password" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
            Password
          </label>
          <div class="relative">
            <span class="absolute inset-y-0 left-3.5 flex items-center text-slate-400 text-lg pointer-events-none">🔒</span>
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="new-password"
              required
              minlength="6"
              placeholder="At least 6 characters"
              class="w-full pl-10 pr-12 py-3 rounded-xl border border-slate-200 dark:border-slate-700
                     bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white
                     placeholder:text-slate-400 text-sm
                     focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent
                     transition-all duration-200"
            />
            <button type="button" id="toggle-password"
              class="absolute inset-y-0 right-3.5 flex items-center text-slate-400 hover:text-slate-600 text-sm">👁️</button>
          </div>

          <!-- Password strength bar -->
          <div class="mt-2 h-1 w-full bg-slate-100 dark:bg-slate-700 rounded-full overflow-hidden">
            <div id="strength-bar" class="h-full rounded-full transition-all duration-300 w-0"></div>
          </div>
          <p id="strength-label" class="text-xs text-slate-400 mt-1">Password strength</p>
        </div>

        <!-- Confirm Password -->
        <div>
          <label for="confirmPassword" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
            Confirm password
          </label>
          <div class="relative">
            <span class="absolute inset-y-0 left-3.5 flex items-center text-slate-400 text-lg pointer-events-none">🔐</span>
            <input
              id="confirmPassword"
              name="confirmPassword"
              type="password"
              autocomplete="new-password"
              required
              placeholder="Repeat your password"
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700
                     bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white
                     placeholder:text-slate-400 text-sm
                     focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent
                     transition-all duration-200"
            />
          </div>
          <p id="match-label" class="text-xs text-slate-400 mt-1 hidden"></p>
        </div>

        <!-- Optional Profile Picture -->
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
            Profile picture <span class="text-slate-400 font-normal">(optional)</span>
          </label>
          <label for="profilePicture"
            class="flex items-center gap-3 px-4 py-3 rounded-xl border-2 border-dashed
                   border-slate-200 dark:border-slate-700 cursor-pointer
                   hover:border-accent hover:bg-accent/5 transition-all duration-200 group">
            <span class="text-2xl">📸</span>
            <div>
              <p id="file-label" class="text-sm text-slate-500 dark:text-slate-400 group-hover:text-accent transition-colors">
                Click to upload a photo
              </p>
              <p class="text-xs text-slate-400">JPEG, PNG, WebP · max 5 MB</p>
            </div>
          </label>
          <input id="profilePicture" name="profilePicture" type="file"
                 accept="image/jpeg,image/png,image/webp" class="sr-only" />
        </div>

        <!-- Terms -->
        <div class="flex items-start gap-3">
          <input id="terms" name="terms" type="checkbox" required
            class="mt-0.5 w-4 h-4 rounded border-slate-300 text-accent focus:ring-accent cursor-pointer" />
          <label for="terms" class="text-sm text-slate-500 dark:text-slate-400 cursor-pointer leading-relaxed">
            I agree to the
            <a href="#" class="text-accent hover:underline">Terms of Service</a>
            and
            <a href="#" class="text-accent hover:underline">Privacy Policy</a>
          </label>
        </div>

        <!-- Submit -->
        <button
          id="signup-submit"
          type="submit"
          class="w-full flex items-center justify-center gap-2 py-3 px-4 rounded-xl
                 bg-accent hover:bg-accent-hover text-white font-semibold text-sm
                 shadow-sm hover:shadow-md hover:-translate-y-0.5
                 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
        >
          Create Account
          <span class="text-base">🚀</span>
        </button>

      </form>

    </div>
  </div>

</div>

<script>
  // ── Password show/hide ────────────────────────────────────
  document.getElementById('toggle-password').addEventListener('click', function () {
    const input = document.getElementById('password');
    const isText = input.type === 'text';
    input.type = isText ? 'password' : 'text';
    this.textContent = isText ? '👁️' : '🙈';
  });

  // ── Password strength meter ───────────────────────────────
  const passwordInput = document.getElementById('password');
  const strengthBar   = document.getElementById('strength-bar');
  const strengthLabel = document.getElementById('strength-label');

  passwordInput.addEventListener('input', function () {
    const val = this.value;
    let score = 0;
    if (val.length >= 6)  score++;
    if (val.length >= 10) score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;

    const levels = [
      { w: '0%',   color: '',                 label: 'Password strength' },
      { w: '25%',  color: 'bg-red-500',       label: 'Weak' },
      { w: '50%',  color: 'bg-amber-400',     label: 'Fair' },
      { w: '75%',  color: 'bg-yellow-400',    label: 'Good' },
      { w: '100%', color: 'bg-emerald-500',   label: 'Strong 💪' },
    ];

    const level = levels[Math.min(score, 4)];
    strengthBar.style.width   = level.w;
    strengthBar.className     = `h-full rounded-full transition-all duration-300 ${level.color}`;
    strengthLabel.textContent = level.label;
  });

  // ── Confirm password match indicator ─────────────────────
  const confirmInput = document.getElementById('confirmPassword');
  const matchLabel   = document.getElementById('match-label');

  confirmInput.addEventListener('input', function () {
    if (!this.value) { matchLabel.classList.add('hidden'); return; }
    matchLabel.classList.remove('hidden');
    if (this.value === passwordInput.value) {
      matchLabel.textContent = '✅ Passwords match';
      matchLabel.className   = 'text-xs text-emerald-500 mt-1';
    } else {
      matchLabel.textContent = '❌ Passwords do not match';
      matchLabel.className   = 'text-xs text-red-500 mt-1';
    }
  });

  // ── Profile picture filename display ─────────────────────
  document.getElementById('profilePicture').addEventListener('change', function () {
    const label = document.getElementById('file-label');
    label.textContent = this.files[0] ? this.files[0].name : 'Click to upload a photo';
  });

  // ── Submit loading state ──────────────────────────────────
  document.getElementById('signup-form').addEventListener('submit', function (e) {
    const pwd     = document.getElementById('password').value;
    const confirm = document.getElementById('confirmPassword').value;
    const terms   = document.getElementById('terms').checked;

    if (pwd !== confirm) {
      e.preventDefault();
      alert('Passwords do not match.');
      return;
    }
    if (!terms) {
      e.preventDefault();
      alert('You must agree to the Terms of Service.');
      return;
    }

    const btn = document.getElementById('signup-submit');
    btn.innerHTML = '<svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg> Creating account…';
    btn.disabled = true;
  });
</script>