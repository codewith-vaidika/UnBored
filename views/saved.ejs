<% layout('/layouts/boilerplate') %>

<%# ═══════════════════════════════════════════════════════════
    SAVED ACTIVITIES — Full page view
════════════════════════════════════════════════════════════ %>

<div class="max-w-7xl mx-auto px-6 py-12">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-12">
    <div>
      <h1 class="font-jakarta text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-white flex items-center gap-3">
        <i data-lucide="heart" class="w-8 h-8 text-rose-500 fill-rose-500"></i> Your Saved Activities
      </h1>
      <p class="text-slate-500 dark:text-slate-400 font-medium mt-2">
        <%= savedActivities.length %> activit<%= savedActivities.length === 1 ? 'y' : 'ies' %> saved
      </p>
    </div>
    <a href="/dashboard"
       class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full
              bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-jakarta font-bold text-sm
              shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
      <i data-lucide="compass" class="w-4 h-4"></i> Find More Ideas
    </a>
  </div>

  <% if (savedActivities.length === 0) { %>
    <!-- Empty state -->
    <div class="flex flex-col items-center justify-center py-24 text-center
                rounded-3xl border border-dashed border-slate-300 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/30">
      <div class="w-20 h-20 rounded-2xl bg-white dark:bg-slate-800 shadow-sm border border-slate-100 dark:border-slate-700 flex items-center justify-center mb-6 text-slate-400">
        <i data-lucide="bookmark-minus" class="w-10 h-10"></i>
      </div>
      <h2 class="font-jakarta text-2xl font-bold text-slate-900 dark:text-white mb-3">Nothing saved yet</h2>
      <p class="text-slate-500 dark:text-slate-400 font-medium mb-8 max-w-sm leading-relaxed">
        Go to your dashboard, ask the AI for recommendations, and tap the heart on the ones you love.
      </p>
      <a href="/dashboard"
         class="inline-flex items-center gap-2 px-8 py-4 rounded-full
                bg-white border border-slate-200 text-slate-900 font-jakarta font-bold text-sm
                shadow-sm hover:shadow-md hover:-translate-y-0.5 hover:bg-slate-50 transition-all duration-200">
        Go to Dashboard
      </a>
    </div>

  <% } else { %>

    <!-- Filter chips -->
    <% const cats = [...new Set(savedActivities.map(a => a.category))]; %>
    <div class="flex flex-wrap items-center gap-2 mb-10">
      <span class="text-xs font-bold uppercase tracking-wider text-slate-400 mr-2">Filter:</span>
      <button onclick="filterSaved('all')" data-filter="all"
        class="saved-filter px-4 py-2 rounded-full text-xs font-bold transition-all duration-200 bg-slate-900 dark:bg-white text-white dark:text-slate-900 shadow-sm">
        All (<%= savedActivities.length %>)
      </button>
      <% cats.forEach(cat => { %>
        <button onclick="filterSaved('<%= cat %>')" data-filter="<%= cat %>"
          class="saved-filter px-4 py-2 rounded-full text-xs font-bold bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700 hover:border-slate-900 dark:hover:border-white transition-all duration-200 shadow-sm">
          <%= cat %>
        </button>
      <% }) %>
    </div>

    <!-- Saved cards grid -->
    <div id="saved-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <%
        const catIcon = {
          "Creative":"palette","Outdoor":"mountain","Gaming":"gamepad-2","Fitness":"activity",
          "Music":"music","Reading":"book-open","Travel":"plane","Food & Cooking":"utensils",
          "Movies & Shows":"film","Social":"users","Mindfulness":"wind",
          "Learning":"graduation-cap","DIY & Crafts":"wrench","Photography":"camera","General":"sparkles"
        };
      %>
      <% savedActivities.forEach((activity, idx) => {
        const icon = catIcon[activity.category] || 'star';
      %>

      <div class="saved-card group relative flex flex-col rounded-3xl overflow-hidden bg-white dark:bg-slate-800
                  shadow-sm hover:shadow-md border border-slate-200 dark:border-slate-700
                  hover:-translate-y-1 transition-all duration-300"
           data-category="<%= activity.category %>">

        <!-- Header -->
        <div class="p-6 pb-4">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 rounded-2xl bg-slate-50 dark:bg-slate-900/50 flex items-center justify-center text-slate-600 dark:text-slate-300 border border-slate-100 dark:border-slate-700">
              <i data-lucide="<%= icon %>" class="w-6 h-6"></i>
            </div>
            
            <button
              class="remove-btn flex items-center justify-center w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-700 text-slate-400 hover:bg-red-100 hover:text-red-500 transition-colors"
              data-id="<%= activity._id %>"
              data-title="<%= activity.title %>"
              aria-label="Remove"
            >
              <i data-lucide="trash-2" class="w-4 h-4"></i>
            </button>
          </div>
          
          <span class="inline-block px-2.5 py-1 rounded-md bg-slate-100 dark:bg-slate-700/50 text-slate-500 dark:text-slate-400 text-xs font-bold uppercase tracking-wider mb-3">
            <%= activity.category %>
          </span>
          
          <h3 class="font-jakarta text-lg font-bold text-slate-900 dark:text-white line-clamp-2 leading-tight">
            <%= activity.title %>
          </h3>
        </div>

        <!-- Body -->
        <div class="px-6 pb-6 flex flex-col flex-1">
          <p class="text-sm font-medium text-slate-500 dark:text-slate-400 leading-relaxed line-clamp-3 mb-6 flex-1">
            <%= activity.description %>
          </p>

          <div class="flex items-center gap-4 mb-4">
            <div class="flex items-center gap-1.5 text-xs font-medium text-slate-500 dark:text-slate-400">
              <i data-lucide="clock" class="w-3.5 h-3.5"></i>
              <%= activity.estimatedTime || 'Varies' %>
            </div>
            <div class="flex items-center gap-1.5 text-xs font-medium <%= (activity.estimatedCost || '').toLowerCase() === 'free' ? 'text-emerald-600 dark:text-emerald-400' : 'text-slate-500 dark:text-slate-400' %>">
              <i data-lucide="coins" class="w-3.5 h-3.5"></i>
              <%= activity.estimatedCost || 'Free' %>
            </div>
          </div>

          <!-- Saved date -->
          <div class="pt-4 border-t border-slate-100 dark:border-slate-700/50 flex items-center justify-between">
            <span class="text-xs font-medium text-slate-400 dark:text-slate-500 flex items-center gap-1.5">
              <i data-lucide="calendar" class="w-3 h-3"></i>
              Saved <%= new Date(activity.savedAt).toLocaleDateString('en-IN', { day:'numeric', month:'short' }) %>
            </span>
          </div>
        </div>

      </div>

      <% }) %>
    </div>

  <% } %>

</div>

<!-- Remove toast -->
<div id="remove-toast" class="fixed bottom-6 right-6 z-50 hidden
     flex items-center gap-3 px-6 py-4 rounded-2xl shadow-2xl
     bg-slate-900 dark:bg-slate-800 border border-slate-700
     text-sm font-bold text-white">
  <i data-lucide="info" class="w-5 h-5 text-blue-400"></i>
  <span id="remove-toast-msg"></span>
</div>

<script>
// ── Category filter ───────────────────────────────────────────
function filterSaved(cat) {
  document.querySelectorAll('.saved-card').forEach(card => {
    card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
  });
  document.querySelectorAll('.saved-filter').forEach(btn => {
    const active = btn.dataset.filter === cat;
    
    // Toggle active state classes
    if (active) {
      btn.classList.add('bg-slate-900', 'dark:bg-white', 'text-white', 'dark:text-slate-900');
      btn.classList.remove('bg-white', 'dark:bg-slate-800', 'text-slate-600', 'dark:text-slate-300', 'border', 'border-slate-200', 'dark:border-slate-700');
    } else {
      btn.classList.remove('bg-slate-900', 'dark:bg-white', 'text-white', 'dark:text-slate-900');
      btn.classList.add('bg-white', 'dark:bg-slate-800', 'text-slate-600', 'dark:text-slate-300', 'border', 'border-slate-200', 'dark:border-slate-700');
    }
  });
}

// ── Remove activity ───────────────────────────────────────────
document.querySelectorAll('.remove-btn').forEach(btn => {
  btn.addEventListener('click', async function (e) {
    e.preventDefault();
    e.stopPropagation();
    const id    = this.dataset.id;
    const title = this.dataset.title;
    const card  = this.closest('.saved-card');

    if (!confirm(`Remove "${title}"?`)) return;

    try {
      const res  = await fetch(`/activity/${id}`, {
        method : 'DELETE',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json();

      if (res.ok && data.success) {
        card.style.opacity   = '0';
        card.style.transform = 'scale(0.95)';
        card.style.transition= 'opacity 0.25s, transform 0.25s';
        setTimeout(() => card.remove(), 250);
        showToast(`"${title}" removed.`);
      } else {
        alert(data.message || 'Could not remove.');
      }
    } catch { alert('Network error. Please try again.'); }
  });
});

function showToast(msg) {
  const t = document.getElementById('remove-toast');
  document.getElementById('remove-toast-msg').textContent = msg;
  t.classList.remove('hidden');
  clearTimeout(t._tm);
  t._tm = setTimeout(() => t.classList.add('hidden'), 3500);
}
</script>