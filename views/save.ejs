<% layout('/layouts/boilerplate') %>

<%# ═══════════════════════════════════════════════════════════
    SAVED ACTIVITIES — Full page view
════════════════════════════════════════════════════════════ %>

<div class="max-w-7xl mx-auto px-6 py-12">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-10">
    <div>
      <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white flex items-center gap-3">
        ❤️ Your Saved Activities
      </h1>
      <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">
        <%= savedActivities.length %> activit<%= savedActivities.length === 1 ? 'y' : 'ies' %> saved
      </p>
    </div>
    <a href="/dashboard"
       class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl
              bg-accent hover:bg-accent-hover text-white text-sm font-semibold
              shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
      ✨ Find More Ideas
    </a>
  </div>

  <% if (savedActivities.length === 0) { %>
    <!-- Empty state -->
    <div class="flex flex-col items-center justify-center py-24 text-center
                rounded-3xl border-2 border-dashed border-slate-200 dark:border-slate-700">
      <span class="text-6xl mb-5">🌟</span>
      <h2 class="text-2xl font-bold text-slate-800 dark:text-white mb-3">Nothing saved yet</h2>
      <p class="text-slate-500 dark:text-slate-400 text-sm mb-8 max-w-sm">
        Go to your dashboard, ask the AI for recommendations, and tap ❤️ on the ones you love.
      </p>
      <a href="/dashboard"
         class="inline-flex items-center gap-2 px-6 py-3 rounded-xl
                bg-accent hover:bg-accent-hover text-white font-semibold text-sm
                shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
        ✨ Get Recommendations
      </a>
    </div>

  <% } else { %>

    <!-- Filter chips -->
    <% const cats = [...new Set(savedActivities.map(a => a.category))]; %>
    <div class="flex flex-wrap gap-2 mb-8">
      <button onclick="filterSaved('all')" data-filter="all"
        class="saved-filter px-4 py-1.5 rounded-full text-xs font-semibold
               bg-accent text-white transition-all duration-150">
        All (<%= savedActivities.length %>)
      </button>
      <% cats.forEach(cat => { %>
        <button onclick="filterSaved('<%= cat %>')" data-filter="<%= cat %>"
          class="saved-filter px-4 py-1.5 rounded-full text-xs font-semibold
                 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300
                 border border-slate-200 dark:border-slate-700
                 hover:border-accent hover:text-accent transition-all duration-150">
          <%= cat %>
        </button>
      <% }) %>
    </div>

    <!-- Saved cards grid -->
    <div id="saved-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <%
        const catEmoji = {
          "Creative":"🎨","Outdoor":"🏃","Gaming":"🎮","Fitness":"💪",
          "Music":"🎵","Reading":"📚","Travel":"✈️","Food & Cooking":"🍳",
          "Movies & Shows":"🎬","Social":"🤝","Mindfulness":"🧘",
          "Learning":"📖","DIY & Crafts":"🔧","Photography":"📸","General":"🌟"
        };
        const gradients = [
          "from-violet-500 to-indigo-600","from-emerald-400 to-teal-600",
          "from-orange-400 to-rose-500","from-cyan-400 to-blue-600",
          "from-fuchsia-500 to-purple-600","from-amber-400 to-orange-500",
        ];
      %>
      <% savedActivities.forEach((activity, idx) => {
        const emoji = catEmoji[activity.category] || '🌟';
        const grad  = gradients[idx % gradients.length];
      %>

      <div class="saved-card group rounded-2xl overflow-hidden bg-white dark:bg-slate-800
                  shadow-sm hover:shadow-xl border border-slate-100 dark:border-slate-700
                  hover:-translate-y-1.5 transition-all duration-300"
           data-category="<%= activity.category %>">

        <!-- Banner -->
        <div class="relative h-36 bg-gradient-to-br <%= grad %> flex items-center justify-center overflow-hidden">
          <span class="text-6xl opacity-30 group-hover:opacity-50 group-hover:scale-110 transition-all duration-300 select-none">
            <%= emoji %>
          </span>
          <!-- Category badge -->
          <div class="absolute top-3 left-3 flex items-center gap-1 px-2.5 py-1
                      rounded-full bg-white/20 backdrop-blur-md text-white text-xs font-medium">
            <%= emoji %> <%= activity.category %>
          </div>
          <!-- Location type -->
          <div class="absolute top-3 right-3 px-2 py-0.5 rounded-full
                      bg-black/20 backdrop-blur-md text-white text-xs">
            <% if (activity.locationType === 'indoor')        { %>🏠
            <% } else if (activity.locationType === 'outdoor'){ %>🌿
            <% } else if (activity.locationType === 'online') { %>💻
            <% } else { %>🔄<% } %>
          </div>
          <!-- Remove btn -->
          <button
            class="remove-btn absolute bottom-3 right-3 flex items-center gap-1.5 px-3 py-1
                   rounded-full bg-red-500/80 hover:bg-red-500 backdrop-blur-sm text-white text-xs font-medium
                   opacity-0 group-hover:opacity-100 transition-all duration-200"
            data-id="<%= activity._id %>"
            data-title="<%= activity.title %>"
          >
            🗑️ Remove
          </button>
        </div>

        <!-- Body -->
        <div class="p-5">
          <h3 class="font-bold text-slate-900 dark:text-white mb-1.5 line-clamp-1">
            <%= activity.title %>
          </h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed line-clamp-3 mb-4">
            <%= activity.description %>
          </p>

          <!-- Chips -->
          <div class="flex items-center flex-wrap gap-1.5 mb-4">
            <span class="text-xs bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400 px-2.5 py-0.5 rounded-full">
              ⏱️ <%= activity.estimatedTime || 'Varies' %>
            </span>
            <span class="text-xs <%= (activity.estimatedCost || '').toLowerCase() === 'free' ? 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400' : 'bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400' %> px-2.5 py-0.5 rounded-full">
              💰 <%= activity.estimatedCost || 'Free' %>
            </span>
          </div>

          <!-- Saved date -->
          <p class="text-xs text-slate-300 dark:text-slate-600">
            Saved <%= new Date(activity.savedAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
          </p>
        </div>

      </div>

      <% }) %>
    </div>

  <% } %>

</div>

<!-- Remove toast -->
<div id="remove-toast" class="fixed bottom-6 right-6 z-50 hidden
     flex items-center gap-3 px-5 py-3.5 rounded-2xl shadow-xl
     bg-white dark:bg-slate-800 border border-red-200 dark:border-red-800
     text-sm font-medium text-slate-700 dark:text-slate-200">
  <span>🗑️</span>
  <span id="remove-toast-msg"></span>
</div>

<script>
// ── Category filter ───────────────────────────────────────────
function filterSaved(cat) {
  document.querySelectorAll('.saved-card').forEach(card => {
    card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
  });
  document.querySelectorAll('.saved-filter').forEach(btn => {
    const active = btn.dataset.filter === cat;
    btn.classList.toggle('bg-accent',        active);
    btn.classList.toggle('text-white',       active);
    btn.classList.toggle('bg-white',         !active);
    btn.classList.toggle('dark:bg-slate-800',!active);
    btn.classList.toggle('border',           !active);
  });
}

// ── Remove activity ───────────────────────────────────────────
document.querySelectorAll('.remove-btn').forEach(btn => {
  btn.addEventListener('click', async function (e) {
    e.stopPropagation();
    const id    = this.dataset.id;
    const title = this.dataset.title;
    const card  = this.closest('.saved-card');

    if (!confirm(`Remove "${title}"?`)) return;

    try {
      const res  = await fetch(`/activity/${id}`, {
        method : 'DELETE',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json();

      if (res.ok && data.success) {
        card.style.opacity   = '0';
        card.style.transform = 'scale(0.9)';
        card.style.transition= 'opacity 0.25s, transform 0.25s';
        setTimeout(() => card.remove(), 250);
        showToast(`"${title}" removed.`);
      } else {
        alert(data.message || 'Could not remove.');
      }
    } catch { alert('Network error. Please try again.'); }
  });
});

function showToast(msg) {
  const t = document.getElementById('remove-toast');
  document.getElementById('remove-toast-msg').textContent = msg;
  t.classList.remove('hidden');
  clearTimeout(t._tm);
  t._tm = setTimeout(() => t.classList.add('hidden'), 3000);
}
</script>